{
  "name": "@wattry/tsconfig",
  "description": "Base TS configure for new projects",
  "version": "0.2.0",
  "type": "module",
  "author": "wattry",
  "license": "Apache-2.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.13.1",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "10.29.3",
      "onFail": "warn"
    }
  },
  "bin": {
    "tsconfig": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tsconfig.base": "./tsconfig.base.json",
    "./eslint.config": "./eslint.base.js"
  },
  "dependencies": {
    "commander": "14.0.3"
  },
  "files": [
    "dist/**/*",
    "eslint.base.js",
    "tsconfig.base.json"
  ],
  "devDependencies": {
    "@eslint/config-inspector": "1.5.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "25.5.0",
    "dotenv": "^17.3.1",
    "dotenv-expand": "^12.0.3",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  },
  "scripts": {
    "build": "pnpm clean && pnpm tsc --project ./tsconfig.json",
    "build:pack": "pnpm build && pnpm pack",
    "clean": "rm -rf dist",
    "dev": "tsx watch --include './src/**/*.ts' ./src/index.ts",
    "lint": "eslint  --config ./eslint.config.js --no-warn-ignored src/**/*.ts",
    "lint:config": "pnpx @eslint/config-inspector@latest --config ./eslint.config.js",
    "lint:fix": "eslint  --config ./eslint.config.js --fix --no-warn-ignored src/**/*.ts",
    "prepare": "pnpm run build",
    "test:ci": "vitest . --silent --collectCoverage --coverageDirectory='./coverage' --ci --reporters=default --reporters=junit --watchAll=false --passWithNoTests",
    "test:watch": "vitest . --passWithNoTests --watch",
    "test": "vitest . --passWithNoTests",
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "upgrade:all": "pnpm update --latest"
  }
}