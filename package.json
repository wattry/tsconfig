{
  "name": "@wattry/tsconfig",
  "description": "Base config for bootstrapping and maintaining Typescript projects",
  "version": "0.4.3",
  "type": "module",
  "author": "wattry",
  "private": "false",
  "repository": "https://github.com/wattry/tsconfig",
  "license": "Apache-2.0",
  "keywords": [
    "Typescript",
    "lint",
    "eslint",
    "vite",
    "config",
    "configuration"
  ],
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.3.0",
      "onFail": "warn"
    }
  },
  "bin": {
    "tsconfig": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./base": "./tsconfig.base.json",
    "./eslint": {
      "types": "./types/eslint.base.d.ts",
      "default": "./eslint.base.js"
    },
    "./vitest": {
      "types": "./types/vitest.config.d.ts",
      "default": "./vitest.config.js"
    }
  },
  "dependencies": {
    "commander": "15.0.0"
  },
  "files": [
    "dist/**/*",
    "types/**/*",
    "eslint.base.ts",
    "eslint.config.ts",
    "tsconfig.json",
    "tsconfig.base.json",
    "tsconfig.build.json",
    "vitest.config.ts"
  ],
  "devDependencies": {
    "@eslint/config-helpers": "0.6.0",
    "@eslint/config-inspector": "3.0.4",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "24.12.4",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jiti": "^2.7.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  },
  "scripts": {
    "build": "pnpm clean && pnpm tsc --project ./tsconfig.build.json",
    "build:pack": "pnpm build && pnpm pack && pnpm clean",
    "clean": "rm -rf dist",
    "dev": "tsx watch --include './src/**/*.ts' ./src/index.ts",
    "lint": "eslint  --config ./eslint.config.ts --no-warn-ignored src/**/*.ts",
    "lint:config": "pnpx @eslint/config-inspector@latest --config ./eslint.config.ts",
    "lint:fix": "eslint  --config ./eslint.config.ts --fix --no-warn-ignored src/**/*.ts",
    "prepare": "pnpm run build",
    "test:ci": "vitest . --silent --collectCoverage --coverageDirectory='./coverage' --ci --reporters=default --reporters=junit --watchAll=false --passWithNoTests",
    "test:watch": "vitest . --passWithNoTests --watch",
    "test": "vitest . --passWithNoTests",
    "typecheck": "tsc --noEmit --project ./tsconfig.json",
    "upgrade:all": "pnpm update --latest"
  }
}