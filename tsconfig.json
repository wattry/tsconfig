{
  "extends": "./tsconfig.base.json",
  "include": [
    "src",
    "types",
    "tests",
    "mocks",
    "__tests__",
    "__mocks__",
    "vitest.config.ts",
    "eslint.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "compilerOptions": {
    "lib": [
      "ESNext"
    ],
    "types": [
      "node"
    ],
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ],
    "rootDir": "."
  }
}